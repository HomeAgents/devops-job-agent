# Orchestrator (copy to orchestrator.env on VM; never commit secrets)
ORCHESTRATOR_DATA_DIR=/home/azureuser/orchestrator-data
ORCHESTRATOR_DB=/home/azureuser/orchestrator-data/orchestrator.db
ORCHESTRATOR_ACTIVITY_FILE=/home/azureuser/orchestrator-data/last_activity
ORCHESTRATOR_TZ=Asia/Jerusalem
# Outbound email language: en | he | ru
ORCHESTRATOR_LANGUAGE=he
ORCHESTRATOR_IDLE_MINUTES=15

# Gmail genie4cv@gmail.com — use App Password (same for IMAP+SMTP)
ORCHESTRATOR_SMTP_USER=genie4cv@gmail.com
ORCHESTRATOR_SMTP_PASSWORD=
ORCHESTRATOR_IMAP_USER=genie4cv@gmail.com
ORCHESTRATOR_IMAP_PASSWORD=

# Docker per-user jobs (optional; 0 = run python directly on VM)
ORCHESTRATOR_USE_DOCKER=0
ORCHESTRATOR_DOCKER_IMAGE=job-agent:latest
ORCHESTRATOR_MAX_PARALLEL=2

# Azure VM lifecycle (poll-inbox touches activity; autostop after idle)
# macOS home runtime: leave unset (defaults to off) or set ORCHESTRATOR_SKIP_VM=1
ORCHESTRATOR_VM_AUTOSTART=1
ORCHESTRATOR_VM_AUTOSTOP=1
# ORCHESTRATOR_SKIP_VM=1

# Home Mac LinkedIn: one login for all users (job search only; per-user keywords in DB)
ORCHESTRATOR_LINKEDIN_SHARED_SESSION=1
ORCHESTRATOR_LINKEDIN_OWNER_EMAIL=arkadiy.kats@gmail.com
# LinkedIn expiry alerts go here (not genie4cv@gmail.com):
ORCHESTRATOR_ADMIN_EMAIL=arkadiy.kats@gmail.com
AZURE_VM_RG=rg-home-agents
AZURE_VM_NAME=vm-home-agents

ORCHESTRATOR_FEEDBACK_ENABLED=0

ORCHESTRATOR_BASE_CONFIG=/home/azureuser/apps/devops-job-agent/config.json
GENIE4CV_SETTINGS=/home/azureuser/genie4cv/local.settings.json

# Digest email Remove/Status links (must match in every digest)
ORCHESTRATOR_REMOVE_SECRET=change-me-to-random-hex
# Mac quick tunnel (changes on reboot) — run scripts/sync-remove-base-url.sh after cloudflared starts
ORCHESTRATOR_REMOVE_BASE_URL=https://YOUR-TRYCLOUDFLARE-OR-NAMED-TUNNEL.example.com
# Optional stable tunnel (Cloudflare Zero Trust → copy token from dashboard):
# CLOUDFLARE_TUNNEL_TOKEN=

# Shared inbox: skip Birthday Copilot / ScoutSignal / bounces (see orchestrator/email_filters.py)
# ORCHESTRATOR_IGNORE_SUBJECT_REGEX=extra-pattern-1,extra-pattern-2
